{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "framework": "vite",
  "routes": [
    {
      "src": "/assets/(.*)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*).(js|css|png|jpg|jpeg|gif|svg|ico|json|webp|woff|woff2|ttf|otf)",
      "headers": { "cache-control": "public, max-age=31536000, immutable" },
      "dest": "/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
